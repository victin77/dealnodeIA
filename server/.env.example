# Porta do servidor (no Railway é definida automaticamente)
PORT=4000

# Banco de dados PostgreSQL.
# Local: cole a URL "Public Network" do Postgres do Railway.
# Railway: use a referência ${{Postgres.DATABASE_URL}} no painel.
DATABASE_URL="postgresql://usuario:senha@host:porta/banco"

# Segredo usado para assinar os tokens JWT (troque por algo aleatorio)
JWT_SECRET="troque-este-segredo-por-algo-aleatorio"

# URL do frontend (apenas para CORS em dev; em producao o backend serve o front)
CLIENT_URL="http://localhost:5173"

# ---- IA ----
# Sem nenhuma chave o app roda em modo "mock" (dados de exemplo, sem custo).

# Chave da Groq (GRATIS, sem cartao). https://console.groq.com -> API Keys
GROQ_API_KEY=""

# Chave da OpenAI (opcional, paga). https://platform.openai.com
OPENAI_API_KEY=""

# Provedor: "auto" usa Groq se houver GROQ_API_KEY, senao OpenAI, senao mock.
# Tambem aceita "groq", "openai" ou "mock" para forcar.
TRANSCRIPTION_PROVIDER="auto"
ANALYSIS_PROVIDER="auto"

# Modelos (opcional - ja existem padroes bons)
GROQ_TRANSCRIPTION_MODEL="whisper-large-v3-turbo"
GROQ_ANALYSIS_MODEL="llama-3.3-70b-versatile"
OPENAI_TRANSCRIPTION_MODEL="whisper-1"
OPENAI_ANALYSIS_MODEL="gpt-4o-mini"
